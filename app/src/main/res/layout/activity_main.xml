<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_main.xml – Pantalla de inicio de Tianguis Pro
    Diseño: Alto contraste para uso bajo el sol (colores oscuros sobre fondo oscuro + texto blanco)
    Material Design 3 | Orientación: portrait
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient_primary"
    tools:context=".MainActivity">

    <!-- Área del logo / ícono de la app -->
    <ImageView
        android:id="@+id/imgLogo"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_marginTop="72dp"
        android:src="@mipmap/ic_launcher_round"
        android:contentDescription="Logo Tianguis Pro"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Nombre de la app -->
    <TextView
        android:id="@+id/tvAppName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="@string/app_name"
        android:textColor="@color/white"
        android:textSize="36sp"
        android:textStyle="bold"
        android:letterSpacing="0.05"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/imgLogo" />

    <!-- Subtítulo / tagline -->
    <TextView
        android:id="@+id/tvTagline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/main_tagline"
        android:textColor="#FFCCBC"
        android:textSize="15sp"
        android:gravity="center"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvAppName" />

    <!-- Contenedor de botones centrado verticalmente -->
    <LinearLayout
        android:id="@+id/layoutButtons"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="32dp"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvTagline">

        <!-- Botón Vendedor (relleno, color primario) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnVendedor"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginBottom="16dp"
            android:text="@string/btn_vendor"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/md_theme_primary"
            style="@style/Widget.Material3.Button.TonalButton"
            app:backgroundTint="@color/white"
            app:icon="@android:drawable/ic_menu_manage"
            app:iconGravity="textStart"
            app:cornerRadius="16dp" />

        <!-- Botón Cliente (contorno blanco) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCliente"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:text="@string/btn_client"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            style="@style/Widget.Material3.Button.OutlinedButton"
            app:strokeColor="@color/white"
            app:strokeWidth="2dp"
            app:icon="@android:drawable/ic_menu_gallery"
            app:iconGravity="textStart"
            app:iconTint="@color/white"
            app:cornerRadius="16dp" />

    </LinearLayout>

    <!-- Versión de la app -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:text="v1.0"
        android:textColor="#FFCCBC"
        android:textSize="12sp"
        android:alpha="0.7"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
