<?xml version="1.0" encoding="utf-8"?>
<!--
    Paleta Minimalista — Tianguis Pro
    Sistema de color muted inspirado en moda de lujo.
    Tonos tierra, grises suaves y monocromáticos.
-->
<resources>
    <!-- ── Primario: Negro carbón ─────────────────────────────── -->
    <color name="md_theme_primary">#1A1A18</color>
    <color name="md_theme_on_primary">#F8F6F2</color>
    <color name="md_theme_primary_container">#2E2E2C</color>
    <color name="md_theme_on_primary_container">#E5E3DE</color>

    <!-- ── Secundario: Tierra cálido ─────────────────────────── -->
    <color name="md_theme_secondary">#A08C7B</color>
    <color name="md_theme_on_secondary">#F8F6F2</color>
    <color name="md_theme_secondary_container">#EDE8DF</color>
    <color name="md_theme_on_secondary_container">#4A4845</color>

    <!-- ── Fondos y superficies ───────────────────────────────── -->
    <color name="md_theme_background">#F8F6F2</color>   <!-- Blanco roto -->
    <color name="md_theme_on_background">#1A1A18</color>
    <color name="md_theme_surface">#F8F6F2</color>
    <color name="md_theme_on_surface">#1A1A18</color>
    <color name="md_theme_surface_variant">#EDE8DF</color>  <!-- Crema suave -->
    <color name="md_theme_on_surface_variant">#4A4845</color> <!-- Gris grafito -->

    <!-- ── Error ─────────────────────────────────────────────── -->
    <color name="md_theme_error">#8B3A3A</color>
    <color name="md_theme_on_error">#F8F6F2</color>
    <color name="md_theme_error_container">#F2E0E0</color>

    <!-- ── Contornos ──────────────────────────────────────────── -->
    <color name="md_theme_outline">#9A9691</color>
    <color name="md_theme_outline_variant">#E5E3DE</color>  <!-- Gris niebla -->

    <!-- ── Indicadores de stock (muted) ──────────────────────── -->
    <color name="stock_ok">#4A7C59</color>       <!-- Verde musgo -->
    <color name="stock_low">#A08C7B</color>       <!-- Tierra = poco stock -->
    <color name="stock_empty">#8B3A3A</color>     <!-- Vino = sin stock -->

    <!-- ── Precio: negro elegante (no naranja) ───────────────── -->
    <color name="price_color">#1A1A18</color>

    <!-- ── Acento sutil ───────────────────────────────────────── -->
    <color name="accent_warm">#A08C7B</color>     <!-- Tierra cálido -->
    <color name="accent_sand">#C4B49A</color>     <!-- Arena oscura -->

    <!-- ── Gradiente (para drawables existentes) ─────────────── -->
    <color name="gradient_start">#1A1A18</color>
    <color name="gradient_end">#4A4845</color>

    <!-- ── Básicos ────────────────────────────────────────────── -->
    <color name="black">#FF1A1A18</color>
    <color name="white">#FFF8F6F2</color>

    <!-- ── Separadores ───────────────────────────────────────── -->
    <color name="divider">#E5E3DE</color>
</resources>
