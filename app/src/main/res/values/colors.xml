<?xml version="1.0" encoding="utf-8"?>
<!--
    Paleta de colores – Material Design 3
    Diseñada para ALTO CONTRASTE bajo el sol (uso en tianguis al aire libre).
    Primario: Naranja profundo (#BF360C) – máxima visibilidad.
    Secundario: Azul oscuro (#1A237E) – excelente legibilidad.
    Fondo: Blanco cálido (#FFFDE7) – reduce el deslumbramiento.
-->
<resources>
    <!-- Colores primarios -->
    <color name="md_theme_primary">#BF360C</color>
    <color name="md_theme_on_primary">#FFFFFF</color>
    <color name="md_theme_primary_container">#FFCCBC</color>
    <color name="md_theme_on_primary_container">#4E0000</color>

    <!-- Colores secundarios -->
    <color name="md_theme_secondary">#1A237E</color>
    <color name="md_theme_on_secondary">#FFFFFF</color>
    <color name="md_theme_secondary_container">#C5CAE9</color>
    <color name="md_theme_on_secondary_container">#000051</color>

    <!-- Fondos y superficies -->
    <color name="md_theme_background">#FFFDE7</color>
    <color name="md_theme_on_background">#1C1B1F</color>
    <color name="md_theme_surface">#FFFDE7</color>
    <color name="md_theme_on_surface">#1C1B1F</color>
    <color name="md_theme_surface_variant">#F5F0EB</color>
    <color name="md_theme_on_surface_variant">#4A4540</color>

    <!-- Error -->
    <color name="md_theme_error">#B71C1C</color>
    <color name="md_theme_on_error">#FFFFFF</color>
    <color name="md_theme_error_container">#FFCDD2</color>

    <!-- Contorno y divisores -->
    <color name="md_theme_outline">#79747E</color>
    <color name="md_theme_outline_variant">#CAC4D0</color>

    <!-- Indicadores de stock -->
    <color name="stock_ok">#1B5E20</color>       <!-- Verde oscuro = hay stock -->
    <color name="stock_low">#E65100</color>       <!-- Naranja = poco stock -->
    <color name="stock_empty">#B71C1C</color>     <!-- Rojo = sin stock -->

    <!-- Precio destacado -->
    <color name="price_color">#BF360C</color>

    <!-- Gradiente principal (para fondos de pantalla) -->
    <color name="gradient_start">#BF360C</color>
    <color name="gradient_end">#E64A19</color>

    <!-- Básicos -->
    <color name="black">#FF000000</color>
    <color name="white">#FFFFFFFF</color>
</resources>
