<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Base.Theme.AppDaniel" parent="Theme.Material3.Light.NoActionBar">
        <!-- Primario -->
        <item name="colorPrimary">@color/md_theme_primary</item>
        <item name="colorOnPrimary">@color/md_theme_on_primary</item>
        <item name="colorPrimaryContainer">@color/md_theme_primary_container</item>
        <item name="colorOnPrimaryContainer">@color/md_theme_on_primary_container</item>
        <!-- Secundario -->
        <item name="colorSecondary">@color/md_theme_secondary</item>
        <item name="colorOnSecondary">@color/md_theme_on_secondary</item>
        <item name="colorSecondaryContainer">@color/md_theme_secondary_container</item>
        <item name="colorOnSecondaryContainer">@color/md_theme_on_secondary_container</item>
        <!-- Fondos -->
        <item name="android:colorBackground">@color/md_theme_background</item>
        <item name="colorSurface">@color/md_theme_surface</item>
        <item name="colorOnSurface">@color/md_theme_on_surface</item>
        <item name="colorSurfaceVariant">@color/md_theme_surface_variant</item>
        <item name="colorOnSurfaceVariant">@color/md_theme_on_surface_variant</item>
        <!-- Error -->
        <item name="colorError">@color/md_theme_error</item>
        <item name="colorOnError">@color/md_theme_on_error</item>
        <!-- Status bar oscura (elegante) -->
        <item name="android:statusBarColor">@color/md_theme_primary</item>
        <item name="android:windowLightStatusBar" tools:targetApi="23">false</item>
        <!-- Tipografía: sans-serif limpia -->
        <item name="android:fontFamily">sans-serif</item>
        <!-- Outlines -->
        <item name="colorOutline">@color/md_theme_outline</item>
        <item name="colorOutlineVariant">@color/md_theme_outline_variant</item>
    </style>

    <style name="Theme.AppDaniel" parent="Base.Theme.AppDaniel" />

    <!-- ── Toolbar minimalista ────────────────────────────────── -->
    <style name="TianguisToolbar" parent="Widget.Material3.Toolbar">
        <item name="android:background">@color/md_theme_primary</item>
        <item name="titleTextColor">@color/md_theme_on_primary</item>
        <item name="subtitleTextColor">@color/md_theme_outline</item>
    </style>

    <!-- ── Botón primario: negro sólido con texto blanco roto ── -->
    <style name="Widget.Tianguis.Button.Primary" parent="Widget.Material3.Button">
        <item name="android:minHeight">52dp</item>
        <item name="android:textSize">13sp</item>
        <item name="android:letterSpacing">0.08</item>
        <item name="android:textAllCaps">true</item>
        <item name="backgroundTint">@color/md_theme_primary</item>
        <item name="android:textColor">@color/md_theme_on_primary</item>
        <item name="cornerRadius">4dp</item>
    </style>

    <!-- ── Botón Ghost: solo borde fino ─────────────────────── -->
    <style name="Widget.Tianguis.Button.Ghost" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:minHeight">48dp</item>
        <item name="android:textSize">13sp</item>
        <item name="android:letterSpacing">0.06</item>
        <item name="strokeColor">@color/md_theme_primary</item>
        <item name="strokeWidth">1dp</item>
        <item name="android:textColor">@color/md_theme_primary</item>
        <item name="cornerRadius">4dp</item>
    </style>

    <!-- ── Card producto: sin borde, sombra ultra sutil ──────── -->
    <style name="Widget.Tianguis.ProductCard" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">8dp</item>
        <item name="cardElevation">1dp</item>
        <item name="cardMaxElevation">4dp</item>
        <item name="strokeWidth">0dp</item>
        <item name="cardBackgroundColor">@color/md_theme_surface</item>
    </style>

    <!-- ── TextInput minimalista ──────────────────────────────── -->
    <style name="Widget.Tianguis.TextInput" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/md_theme_primary</item>
        <item name="hintTextColor">@color/md_theme_on_surface_variant</item>
        <item name="boxCornerRadiusBottomEnd">4dp</item>
        <item name="boxCornerRadiusBottomStart">4dp</item>
        <item name="boxCornerRadiusTopEnd">4dp</item>
        <item name="boxCornerRadiusTopStart">4dp</item>
    </style>

</resources>
